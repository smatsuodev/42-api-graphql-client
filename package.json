{
  "name": "42-api-graphql-client",
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "apidog-cli": "^2.1.7",
    "chokidar-cli": "^3.0.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "postman-to-openapi": "^3.0.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": true,
  "scripts": {
    "build": "mesh-compose -o supergraph.graphql",
    "start": "hive-gateway supergraph",
    "dev": "chokidar \"openapi.yml\" \"*.config.ts\" -c \"pkill -f 'bun run start'; bun run build; bun run start\" --initial",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "@graphql-hive/gateway": "^2.5.1",
    "@graphql-mesh/compose-cli": "^1.5.13",
    "@omnigraph/openapi": "^0.109.34"
  }
}
