{
  "name": "42-api-graphql-client",
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/bun": "^1.3.9",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "apidog-cli": "^2.1.7",
    "chokidar-cli": "^3.0.0",
    "jsdom": "^26.0.0",
    "js-yaml": "^4.1.1",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "postman-to-openapi": "^3.0.1",
    "tailwindcss": "^4.1.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": true,
  "scripts": {
    "collect": "bun src/collect/index.ts",
    "build": "mesh-compose -o supergraph.graphql",
    "start": "bun run build; hive-gateway supergraph",
    "dev": "chokidar \"openapi.yml\" \"*.config.ts\" -c \"pkill -f 'bun run start'; bun run build; bun run start\" --initial",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit -p dashboard/tsconfig.json",
    "dev:dashboard": "vite --config dashboard/vite.config.ts",
    "build:dashboard": "vite build --config dashboard/vite.config.ts",
    "test:dashboard": "vitest run --config dashboard/vite.config.ts"
  },
  "dependencies": {
    "@graphql-hive/gateway": "^2.5.1",
    "@graphql-mesh/compose-cli": "^1.5.13",
    "@omnigraph/openapi": "^0.109.34",
    "@tanstack/react-query": "^5.74.0",
    "graphql": "^16.10.0",
    "graphql-request": "^7.1.2",
    "node-html-parser": "^7.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-grid-layout": "^1.5.0",
    "recharts": "^2.15.0"
  }
}
